    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Diagnostics": {
    "IncludeErrorDetails": true
  },
  "Db": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=hrflow.db",
    "SqlServer": "Server=localhost;Database=HrFlow;Trusted_Connection=True;TrustServerCertificate=True",
